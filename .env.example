# SS Veículos — variáveis de ambiente
# Copie este arquivo para `.env.local` (local) e configure no Vercel (produção).
# Os valores estão em: Supabase → Project Settings → API

# URL do projeto Supabase (ex.: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chave pública "anon" do Supabase (pode ser exposta no frontend — protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL final de produção do site (ex.: https://ssveiculoscacoal.com.br)
# Usada para gerar corretamente os links de compartilhamento (WhatsApp/Facebook/Twitter).
# Sem isso, os cards de compartilhamento apontam para "localhost".
NEXT_PUBLIC_SITE_URL=
